{
  "version": 8,
  "name": "ISOM Base Style",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": [
        "https://api.maptiler.com/tiles/v3/{z}/{x}/{y}.pbf?key=SOSAfSwTZ8G9yYdNtF8Z"
      ],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#ffffff"
      }
    },
    {
    "id": "landuse-forest",
    "type": "fill",
    "source": "osm",
    "source-layer": "landuse",
    "filter": ["==", "subclass", "forest"],
    "paint": {
        "fill-color": "#2f6b2f",
        "fill-opacity": 0.85
    }
    },
    {
      "id": "landuse-grass",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["in", "class", "grass", "meadow", "farmland"],
      "paint": {
        "fill-color": "#eaf6e2",
        "fill-opacity": 1
      }
    },
    {
      "id": "residential-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#aba537",
        "fill-opacity": 1
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#009ddc",
        "fill-opacity": 0.9
      }
    },
    {
        "id": "roads-motorway",
        "type": "line",
        "source": "osm",
        "source-layer": "transportation",
        "filter": ["==", "class", "motorway"],
        "paint": {
            "line-color": "#e4af7b",
            "line-width": 2.5
        }
    },
    {
        "id": "roads-trunk",
        "type": "line",
        "source": "osm",
        "source-layer": "transportation",
        "filter": ["==", "class", "trunk"],
        "paint": {
        "line-color": "#e4af7b",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 4,
            18, 20,
            19, 30
            ]
        }
    },
    {
      "id": "roads-primary",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#e4af7b",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 2.5,
            18, 20
            ]
      }
    },
    {
      "id": "roads-secondary",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#d8c9ad",
        "line-width": 1
      }
    },
    {
      "id": "paths",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "footway", "track"],
      "paint": {
        "line-color": "#6b5b3e",
        "line-width": 0.8,
        "line-dasharray": [2, 2]
      }
    },
    {
        "id": "buildings-2d",
        "type": "fill",
        "source": "osm",
        "source-layer": "building",
        "layout": {
            "visibility": "none"
        },
        "paint": {
            "fill-color": "#231f20",
            "fill-opacity": 1
        }
        
    },
    {
        "id": "buildings-3d",
        "type": "fill-extrusion",
        "source": "osm",
        "source-layer": "building",
        "layout": {
            "visibility": "visible"
        },
        "minzoom": 14,
        "paint": {
            "fill-extrusion-color": "#231f20",
            "fill-extrusion-height": [
            "coalesce",
            ["get", "render_height"],
            ["get", "height"],
            10
            ],
            "fill-extrusion-base": [
            "coalesce",
            ["get", "min_height"],
            0
            ],
            "fill-extrusion-opacity": 1
        }
    }
  ]
}